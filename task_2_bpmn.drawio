        </mxCell>
        <mxCell id="note1" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;" value="&lt;b&gt;Статусы товара:&lt;/b&gt;&lt;br&gt;• Черновик — создаётся при сохранении&lt;br&gt;• На модерации — после отправки&lt;br&gt;• Опубликован — на витрине&lt;br&gt;• Отклонён — требует доработки" vertex="1">
          <mxGeometry height="80" width="220" x="40" y="560" as="geometry" />
        </mxCell>
        <mxCell id="note2" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=10;" value="&lt;b&gt;Правила автопроверки:&lt;/b&gt;&lt;br&gt;• Нет запрещённых слов&lt;br&gt;• Фото: 1–10 шт, формат JPG/PNG&lt;br&gt;• Цена &gt; 0, количество ≥ 1&lt;br&gt;• Категория выбрана из справочника" vertex="1">
